# Nearby Marketplace — local development environment
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# PostgreSQL connection string (use the external Render URL for local dev)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# JWT signing secret — any long random string works for local dev
JWT_SECRET=change-me-to-a-long-random-string

# Optional: Voyage AI for product embedding (leave blank to disable)
VOYAGE_API_KEY=
